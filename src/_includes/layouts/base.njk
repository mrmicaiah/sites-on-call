<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ title | default("Sites On Call — Websites for Contractors in North Alabama") }}</title>
  <meta name="description" content="{{ description | default("Websites and SEO content for contractors tired of Angi, HomeAdvisor, and expensive Google Ads. Build an asset you own. No contracts.") }}">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/styles.css">
  
  {# Open Graph tags #}
  <meta property="og:title" content="{{ title | default('Sites On Call') }}">
  <meta property="og:description" content="{{ description | default('Websites for contractors who are done paying for leads.') }}">
  <meta property="og:type" content="{{ ogType | default('website') }}">
  <meta property="og:url" content="https://sitesoncall.com{{ page.url }}">
  {% if image %}
  <meta property="og:image" content="{{ image }}">
  {% endif %}
  
  {# Canonical URL #}
  <link rel="canonical" href="https://sitesoncall.com{{ page.url }}">
  
  {# LocalBusiness Schema - Only on homepage #}
  {% if page.url == '/' %}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "LocalBusiness",
    "@id": "https://sitesoncall.com/#organization",
    "name": "Sites On Call",
    "description": "Web design and SEO services for contractors in North Alabama. We help plumbers, HVAC technicians, roofers, and other service businesses stop paying for leads and start owning their online presence.",
    "url": "https://sitesoncall.com",
    "telephone": "+1-205-672-6673",
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Huntsville",
      "addressRegion": "AL",
      "addressCountry": "US"
    },
    "geo": {
      "@type": "GeoCoordinates",
      "latitude": 34.7304,
      "longitude": -86.5861
    },
    "areaServed": [
      { "@type": "City", "name": "Huntsville", "containedInPlace": { "@type": "State", "name": "Alabama" } },
      { "@type": "City", "name": "Madison", "containedInPlace": { "@type": "State", "name": "Alabama" } },
      { "@type": "City", "name": "Decatur", "containedInPlace": { "@type": "State", "name": "Alabama" } },
      { "@type": "City", "name": "Athens", "containedInPlace": { "@type": "State", "name": "Alabama" } },
      { "@type": "City", "name": "Hartselle", "containedInPlace": { "@type": "State", "name": "Alabama" } },
      { "@type": "City", "name": "Cullman", "containedInPlace": { "@type": "State", "name": "Alabama" } },
      { "@type": "City", "name": "Florence", "containedInPlace": { "@type": "State", "name": "Alabama" } }
    ],
    "priceRange": "$$",
    "openingHoursSpecification": {
      "@type": "OpeningHoursSpecification",
      "dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"],
      "opens": "09:00",
      "closes": "17:00"
    },
    "hasOfferCatalog": {
      "@type": "OfferCatalog",
      "name": "Web Design & SEO Services",
      "itemListElement": [
        {
          "@type": "Offer",
          "itemOffered": {
            "@type": "Service",
            "name": "Contractor Website Design",
            "description": "Professional websites for contractors that convert visitors into calls"
          }
        },
        {
          "@type": "Offer",
          "itemOffered": {
            "@type": "Service",
            "name": "Monthly SEO Content",
            "description": "Blog posts and content marketing to help contractors rank on Google"
          }
        },
        {
          "@type": "Offer",
          "itemOffered": {
            "@type": "Service",
            "name": "Local SEO",
            "description": "Google Business Profile optimization and local search visibility for North Alabama contractors"
          }
        }
      ]
    },
    "founder": {
      "@type": "Person",
      "name": "Irene",
      "jobTitle": "Owner"
    }
  }
  </script>
  {% endif %}
</head>
<body>
  <nav id="navbar">
    <div class="nav-inner">
      <a href="/" class="nav-logo">Sites On <span>Call</span></a>
      <ul class="nav-links" id="navLinks">
        <li><a href="/#pricing">Pricing</a></li>
        <li><a href="/#how-it-works">How It Works</a></li>
        <li><a href="/the-build/">The Build</a></li>
        <li><a href="/articles/">Articles</a></li>
        <li><a href="/#about">About</a></li>
        <li><a href="/#faq">FAQ</a></li>
        <li><a href="javascript:void(0)" onclick="openContactModal()" class="nav-cta">Get Started</a></li>
      </ul>
      <button class="mobile-toggle" id="mobileToggle" aria-label="Menu">
        <span></span>
        <span></span>
        <span></span>
      </button>
    </div>
  </nav>

  <main>
    {{ content | safe }}
  </main>

  {# Contact Modal #}
  <div class="modal-overlay" id="contactModal">
    <div class="modal-card">
      <button class="modal-close" onclick="closeContactModal()" aria-label="Close">&times;</button>
      <div class="modal-header">
        <h3>Let's talk about your website</h3>
        <p>Tell me about your business. I'll be in touch within 24 hours.</p>
      </div>
      <div id="formContent">
        <form id="contactForm">
          <div class="form-row">
            <div class="form-group">
              <label for="cf-name">Your name *</label>
              <input type="text" id="cf-name" name="name" placeholder="John Smith" required>
              <span class="form-error">Please enter your name</span>
            </div>
            <div class="form-group">
              <label for="cf-email">Email *</label>
              <input type="email" id="cf-email" name="email" placeholder="john@example.com" required>
              <span class="form-error">Please enter a valid email</span>
            </div>
          </div>
          <div class="form-row">
            <div class="form-group">
              <label for="cf-business">Business name *</label>
              <input type="text" id="cf-business" name="business" placeholder="Smith's Plumbing" required>
              <span class="form-error">Please enter your business name</span>
            </div>
            <div class="form-group">
              <label for="cf-phone">Phone *</label>
              <input type="tel" id="cf-phone" name="phone" placeholder="(256) 555-1234" required>
              <span class="form-error">Please enter your phone number</span>
            </div>
          </div>
          
          {# Snapshot Offer Toggle #}
          <div class="form-group form-toggle-offer snapshot-offer">
            <label class="form-toggle" id="snapshotToggle">
              <input type="checkbox" id="cf-snapshot" name="wants_snapshot" value="yes">
              <span class="toggle-indicator">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              </span>
              <span class="toggle-content">
                <span class="toggle-title">Send me a free Online Presence Snapshot <span class="free-badge">Free</span></span>
                <span class="toggle-desc">I'll show you what's working, what's broken, and who's outranking you on Google.</span>
              </span>
            </label>
          </div>
          
          {# Schedule Call Toggle #}
          <div class="form-group form-toggle-offer schedule-offer">
            <label class="form-toggle" id="scheduleToggle">
              <input type="checkbox" id="cf-schedule" name="wants_call" value="yes">
              <span class="toggle-indicator">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              </span>
              <span class="toggle-content">
                <span class="toggle-title">Schedule a phone call</span>
                <span class="toggle-desc">Pick a time and I'll call you to discuss your project.</span>
              </span>
            </label>
          </div>
          
          {# Schedule Fields (hidden by default) #}
          <div class="schedule-fields" id="scheduleFields" style="display:none">
            <div class="form-row">
              <div class="form-group">
                <label for="cf-date">Preferred date <span style="color:var(--muted);font-weight:400">(Mon-Fri)</span></label>
                <input type="date" id="cf-date" name="call_date">
              </div>
              <div class="form-group">
                <label for="cf-time">Preferred time <span style="color:var(--muted);font-weight:400">(Central)</span></label>
                <select id="cf-time" name="call_time">
                  <option value="">Select a time...</option>
                  <option value="9:00 AM">9:00 AM</option>
                  <option value="10:00 AM">10:00 AM</option>
                  <option value="11:00 AM">11:00 AM</option>
                  <option value="1:00 PM">1:00 PM</option>
                  <option value="2:00 PM">2:00 PM</option>
                  <option value="3:00 PM">3:00 PM</option>
                  <option value="4:00 PM">4:00 PM</option>
                </select>
              </div>
            </div>
          </div>
          
          <div class="form-group">
            <label for="cf-package">Which package interests you?</label>
            <select id="cf-package" name="package">
              <option value="">Not sure yet</option>
              <option value="founding-client">🚀 Founding Client Program (50% off)</option>
              <option value="starter">Starter ($149/mo)</option>
              <option value="standard">Standard ($299/mo)</option>
              <option value="growth">Growth ($449/mo)</option>
              <option value="annual-starter">Annual Starter ($1,788/yr + free site)</option>
              <option value="annual-standard">Annual Standard ($3,588/yr + free site)</option>
              <option value="annual-growth">Annual Growth ($5,388/yr + free site)</option>
              <option value="website-only">Just the website</option>
            </select>
          </div>
          <div class="form-group">
            <label for="cf-message">Anything else? <span style="color:var(--muted);font-weight:400">(optional)</span></label>
            <textarea id="cf-message" name="message" rows="2" placeholder="I need a website for my HVAC business..."></textarea>
          </div>
          <button type="submit" class="btn-primary" id="cfSubmit" style="width:100%;justify-content:center;margin-top:0.75rem">
            Send Message 
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 2L11 13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
          </button>
        </form>
      </div>
      <div id="formSuccess" style="display:none;text-align:center;padding:2rem 0">
        <div style="width:64px;height:64px;background:var(--green-light);border-radius:50%;display:flex;align-items:center;justify-content:center;margin:0 auto 1.5rem">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="var(--green)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
        </div>
        <h3 style="margin-bottom:0.5rem">Got it!</h3>
        <p style="color:var(--slate);line-height:1.7">I'll be in touch within 24 hours.</p>
      </div>
    </div>
  </div>

  <footer>
    <div class="footer-inner">
      <div class="footer-logo">Sites On <span>Call</span></div>
      <ul class="footer-links">
        <li><a href="/#pricing">Pricing</a></li>
        <li><a href="/#how-it-works">How It Works</a></li>
        <li><a href="/the-build/">The Build</a></li>
        <li><a href="/articles/">Articles</a></li>
        <li><a href="/#about">About</a></li>
        <li><a href="/#faq">FAQ</a></li>
        <li><a href="javascript:void(0)" onclick="openContactModal()">Contact</a></li>
      </ul>
      <p style="font-size:0.82rem">&copy; {{ "" | year }} Sites On Call. All rights reserved.</p>
    </div>
  </footer>

  <script src="/js/main.js"></script>
</body>
</html>
