<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ title | default("Sites On Call — Free Website Design & Strategic Content Growth") }}</title>
  <meta name="description" content="{{ description | default("We design your website for free. Then our team of writers creates strategic content that drives organic traffic and grows your business every month.") }}">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/styles.css">
  
  {# Open Graph tags #}
  <meta property="og:title" content="{{ title | default('Sites On Call') }}">
  <meta property="og:description" content="{{ description | default('Free website design with strategic content growth.') }}">
  <meta property="og:type" content="{{ ogType | default('website') }}">
  <meta property="og:url" content="https://sitesoncall.com{{ page.url }}">
  {% if image %}
  <meta property="og:image" content="{{ image }}">
  {% endif %}
  
  {# Canonical URL #}
  <link rel="canonical" href="https://sitesoncall.com{{ page.url }}">
</head>
<body>
  <nav id="navbar">
    <div class="nav-inner">
      <a href="/" class="nav-logo">Sites On <span>Call</span></a>
      <ul class="nav-links" id="navLinks">
        <li><a href="/#how-it-works">How It Works</a></li>
        <li><a href="/#projects">Projects</a></li>
        <li><a href="/#pricing">Pricing</a></li>
        <li><a href="/articles/">Articles</a></li>
        <li><a href="/#faq">FAQ</a></li>
        <li><a href="javascript:void(0)" onclick="openContactModal()" class="nav-cta">Get Your Free Site</a></li>
      </ul>
      <button class="mobile-toggle" id="mobileToggle" aria-label="Menu">
        <span></span>
        <span></span>
        <span></span>
      </button>
    </div>
  </nav>

  <main>
    {{ content | safe }}
  </main>

  {# Contact Modal #}
  <div class="modal-overlay" id="contactModal">
    <div class="modal-card">
      <button class="modal-close" onclick="closeContactModal()" aria-label="Close">&times;</button>
      <div class="modal-header">
        <h3>Let's build your site</h3>
        <p>Tell us a little about your business and we'll be in touch within 24 hours.</p>
      </div>
      <div id="formContent">
        <form id="contactForm">
          <div class="form-row">
            <div class="form-group">
              <label for="cf-name">Your name *</label>
              <input type="text" id="cf-name" name="name" placeholder="Jane Smith" required>
              <span class="form-error">Please enter your name</span>
            </div>
            <div class="form-group">
              <label for="cf-email">Email *</label>
              <input type="email" id="cf-email" name="email" placeholder="jane@example.com" required>
              <span class="form-error">Please enter a valid email</span>
            </div>
          </div>
          <div class="form-row">
            <div class="form-group">
              <label for="cf-business">Business name *</label>
              <input type="text" id="cf-business" name="business" placeholder="Smith's Plumbing">
              <span class="form-error">Please enter your business name</span>
            </div>
            <div class="form-group">
              <label for="cf-phone">Phone <span style="color:var(--muted);font-weight:400">(optional)</span></label>
              <input type="tel" id="cf-phone" name="phone" placeholder="(555) 123-4567">
            </div>
          </div>
          <div class="form-group">
            <label for="cf-message">What can we help with? <span style="color:var(--muted);font-weight:400">(optional)</span></label>
            <textarea id="cf-message" name="message" rows="3" placeholder="I need a website for my gutter installation business..."></textarea>
          </div>
          <button type="submit" class="btn-primary" id="cfSubmit" style="width:100%;justify-content:center;margin-top:0.75rem">
            Send Message 
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 2L11 13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
          </button>
        </form>
      </div>
      <div id="formSuccess" style="display:none;text-align:center;padding:2rem 0">
        <div style="width:64px;height:64px;background:var(--green-light);border-radius:50%;display:flex;align-items:center;justify-content:center;margin:0 auto 1.5rem">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="var(--green)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
        </div>
        <h3 style="margin-bottom:0.5rem">We got your message!</h3>
        <p style="color:var(--slate);line-height:1.7">We'll be in touch within 24 hours to discuss your project.</p>
      </div>
    </div>
  </div>

  <footer>
    <div class="footer-inner">
      <div class="footer-logo">Sites On <span>Call</span></div>
      <ul class="footer-links">
        <li><a href="/#how-it-works">How It Works</a></li>
        <li><a href="/#pricing">Pricing</a></li>
        <li><a href="/articles/">Articles</a></li>
        <li><a href="/#faq">FAQ</a></li>
        <li><a href="javascript:void(0)" onclick="openContactModal()">Contact</a></li>
      </ul>
      <p style="font-size:0.82rem">&copy; {{ "now" | date: "%Y" }} Sites On Call. All rights reserved.</p>
    </div>
  </footer>

  <script src="/js/main.js"></script>
</body>
</html>