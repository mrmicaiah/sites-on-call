---
layout: layouts/base.njk
title: "Articles — Web Design & SEO Tips for Local Businesses"
description: "Tips, guides, and insights about web design, SEO, and content marketing for local service businesses."
---

<section class="page-hero">
  <div class="section-inner">
    <div class="section-label">Resources</div>
    <h1 class="section-title">Articles</h1>
    <p class="section-subtitle" style="margin:0 auto;">Tips, guides, and insights to help your local business grow online.</p>
  </div>
</section>

<section>
  <div class="section-inner">
    <div class="articles-grid">
      {% for post in collections.posts %}
        <article class="article-card">
          <a href="{{ post.url }}">
            <div class="article-card-content">
              <div class="article-card-date">{{ post.date | readableDate }}</div>
              <h2 class="article-card-title">{{ post.data.title }}</h2>
              <p class="article-card-excerpt">{{ post.data.excerpt }}</p>
            </div>
          </a>
        </article>
      {% else %}
        <div class="empty-state">
          <h3>Coming Soon</h3>
          <p>We're working on helpful articles about web design, SEO, and growing your local business online. Check back soon!</p>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

<section class="final-cta">
  <div class="section-inner">
    <div class="section-label">Ready to grow?</div>
    <h2>Get your free website today</h2>
    <p>Tell us about your business and we'll get started on your custom site.</p>
    <button class="btn-primary" onclick="openContactModal()">
      Let's Talk 
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
    </button>
  </div>
</section>
